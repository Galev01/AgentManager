# Dashboard — copy to apps/dashboard/.env.local and fill in, or run `pnpm bootstrap`.

# Where the dashboard reaches the bridge. Single-host: http://127.0.0.1:3100.
# Split-host: the bridge's private LAN/VPN URL.
OPENCLAW_BRIDGE_URL=http://127.0.0.1:3100

# Mirrors BRIDGE_TOKEN in apps/bridge/.env. Generated by `pnpm bootstrap`.
OPENCLAW_BRIDGE_TOKEN=

# Mirrors AUTH_ASSERTION_SECRET in apps/bridge/.env. Generated by `pnpm bootstrap`.
AUTH_ASSERTION_SECRET=

# HMAC key for the dashboard's session cookie (`ocm_session`). Generate 32+ bytes.
SESSION_SECRET=

# Cookie security. False on plain HTTP LAN; true behind TLS.
COOKIE_SECURE=false

# Bind address / port for `next`/standalone (`server.js`).
# Behind nginx on the same host, use loopback only so port 3000 is not reachable from the LAN:
# HOSTNAME=127.0.0.1
# PORT=3000
